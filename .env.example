# ============================================================
# PDF Reading Agent - LLM Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Model identifier (LiteLLM format)
# Examples:
#   OpenAI:      gpt-4o / gpt-4o-mini
#   DeepSeek:    deepseek/deepseek-chat
#   Zhipu GLM:   zhipuai/glm-4
#   Qwen:        openai/qwen-plus  (use openai prefix + api_base)
#   Ollama:      ollama/llama3
LLM_MODEL=gpt-4o-mini

# API Key for the chosen provider
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx

# (Optional) Custom API base URL
# Required for Qwen (https://dashscope.aliyuncs.com/compatible-mode/v1)
# Required for Ollama (http://localhost:11434)
LLM_API_BASE=

# (Optional) Generation parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# (Optional) Max characters of PDF text injected per chat (lower = faster)
# PDF_CONTEXT_MAX_CHARS=24000

# --- RAG (Phase 2: FAISS + sentence-transformers) ---
# RAG_ENABLED=true
# First run downloads the embedding model (~hundreds of MB).
# RAG_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# RAG_TOP_K=8
# RAG_CHUNK_SIZE=480
# RAG_CHUNK_OVERLAP=90
# RAG_MAX_CONTEXT_CHARS=14000
# RAG_MAX_CHUNKS_PER_DOC=4000
